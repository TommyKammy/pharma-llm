# Copy to .env for local-only settings. Do not commit real secrets.

# Argilla local/self-hosted server
ARGILLA_API_URL=http://localhost:6900
ARGILLA_API_KEY=

# Optional OpenAI-compatible local endpoint used by later evaluation phases
LOCAL_OPENAI_BASE_URL=http://127.0.0.1:8000/v1
LOCAL_OPENAI_API_KEY=

# Local artifact roots. Keep these outside Git when they become large.
PHARMA_LLM_MODEL_DIR=/Users/tsinfra/Dev/pharma-llm/local/models
PHARMA_LLM_ADAPTER_DIR=/Users/tsinfra/Dev/pharma-llm/local/adapters
PHARMA_LLM_RUN_DIR=/Users/tsinfra/Dev/pharma-llm/local/runs
